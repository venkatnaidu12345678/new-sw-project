# Share Wheels backend — copy to `.env` and fill in values.

PORT=3001
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/sharewheels
JWT_SECRET=change_me

# Firebase (FCM + password reset)
FIREBASE_WEB_API_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ROOT_FOLDER=sharewheels

# Google Maps + Vision OCR (enable Cloud Vision API on the same Google Cloud project)
GOOGLE_MAPS_API_KEY=
# Optional dedicated Vision key; falls back to GOOGLE_MAPS_API_KEY when unset
GOOGLE_VISION_API_KEY=

# Razorpay — driver subscription payments (Test mode keys for dev)
# https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=rzp_live_StAJwFR6KStysj
RAZORPAY_KEY_SECRET=ujPTL3CCov4ce2z5sLUWhmVY

# Admin seed (npm run db:setup)
ADMIN_NAME=Share Wheels Admin
ADMIN_EMAIL=admin@sharewheels.com
ADMIN_MOBILE=9999999999
ADMIN_PASSWORD=change_me
