{
  "name": "share-wheels-backend",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon",
    "db:inspect": "node scripts/inspectDatabase.js",
    "db:clear": "node scripts/clearDatabase.js --yes",
    "db:setup": "node scripts/setupDatabase.js",
    "db:seed-lookups": "node scripts/seedLookupTypes.js",
    "db:migrate-user-no": "node scripts/migrateUserNo.js",
    "db:migrate-subscriptions": "node scripts/migrateSubscriptions.js --yes",
    "db:seed-ads": "node scripts/seedSampleAds.js",
    "db:backfill-passwords": "node scripts/backfillPasswordPlain.js",
    "db:reset": "npm run db:clear && npm run db:setup",
    "db:cleanup-requests": "node scripts/cleanupDuplicateRequests.js --yes",
    "test:cloudinary": "node scripts/testCloudinary.js"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "razorpay": "^2.9.6",
    "resend": "^6.12.4",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
