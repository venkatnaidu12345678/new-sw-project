# Local backend (Share-wheels-backend: npm run dev, port 3001)
USE_LOCAL_BACKEND=true

# Physical phone (same Wi‑Fi as PC): run `npm run dev:ip` and paste your PC IP here
LOCAL_API_URL=http://192.168.0.116:3001

# Android emulator only:
# LOCAL_API_URL=http://10.0.2.2:3001

# USB device with port forwarding (after npm run adb:reverse):
# LOCAL_API_URL=http://localhost:3001

# Remote / production (release builds or USE_LOCAL_BACKEND=false)
# USE_LOCAL_BACKEND=false
PRODUCTION_URL=https://new-sw-project.onrender.com
