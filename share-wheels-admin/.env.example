# Local backend (npm run dev in Share-wheels-backend on port 3001)
VITE_API_URL=/api

# Or call the API directly (no Vite proxy)
# VITE_API_URL=http://localhost:3001

# Remote
# VITE_API_URL=https://your-backend.onrender.com

# Browser API key for Live Tracking (NOT the Android-only mobile key).
# Enable Maps JavaScript API + HTTP referrers: http://localhost:5173/*
VITE_GOOGLE_MAPS_API_KEY=your_browser_google_maps_api_key_here
